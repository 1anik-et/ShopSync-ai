{
  "name": "shopsync-server",
  "version": "1.0.0",
  "description": "ShopSync AI Backend API Server",
  "main": "src/index.js",
  "scripts": {
    "dev": "node src/index.js",
    "db:migrate": "npx prisma migrate dev --name init",
    "db:seed": "node prisma/seed.js",
    "db:reset": "npx prisma migrate reset --force",
    "db:studio": "npx prisma studio",
    "postinstall": "npx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "axios": "^1.15.1",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb-memory-server": "^11.0.1",
    "mongoose": "^9.4.1",
    "puppeteer": "^24.42.0"
  },
  "devDependencies": {
    "prisma": "^6.9.0"
  }
}
